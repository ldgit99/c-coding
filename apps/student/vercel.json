{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "cd ../.. && pnpm turbo run build --filter=@cvibe/student",
  "installCommand": "pnpm install --frozen-lockfile",
  "regions": ["icn1"],
  "functions": {
    "app/api/**/route.ts": {
      "maxDuration": 30
    },
    "app/api/events/stream/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/student-modeler/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/student-modeler",
      "schedule": "0 3 * * *"
    }
  ]
}
