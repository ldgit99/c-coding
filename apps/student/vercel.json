{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "cd ../.. && pnpm turbo run build --filter=@cvibe/student",
  "installCommand": "pnpm install --frozen-lockfile",
  "ignoreCommand": "npx turbo-ignore @cvibe/student",
  "regions": ["icn1"],
  "functions": {
    "app/api/**/route.ts": {
      "maxDuration": 30
    },
    "app/api/events/stream/route.ts": {
      "maxDuration": 300
    }
  }
}
