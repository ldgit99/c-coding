# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # 서버 전용, 절대 클라이언트 노출 금지

# Anthropic / Vercel AI Gateway
ANTHROPIC_API_KEY=sk-ant-...
VERCEL_AI_GATEWAY_URL=https://gateway.ai.cloudflare.com/...

# Langfuse (관측성, self-host)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://langfuse.internal

# Judge0 (WASM 실행 fallback)
JUDGE0_API_URL=https://judge0.example.com
JUDGE0_API_KEY=
