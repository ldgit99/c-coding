{
  "name": "@cvibe/db",
  "version": "0.1.0",
  "private": true,
  "description": "Drizzle ORM 스키마 + Supabase 마이그레이션 — students, assignments, submissions, conversations, mastery, events(xAPI), interventions",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./client": "./src/client.ts",
    "./seeds": "./src/seeds/assignments.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "studio": "drizzle-kit studio",
